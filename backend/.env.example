# OceanCred Backend Environment Configuration

# ------------------------------------------------------------------------------------------
# GEMINI VISION AI KEY
# Required for running the actual AI waste detection model in `/upload` endpoints.
# Get a free key from Google AI Studio.
# ------------------------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_goes_here

# ------------------------------------------------------------------------------------------
# OUTGOING EMAIL (winner invoice / outbid notices)
# Without SMTP_HOST, emails are only printed to the server console (mock).
# Gmail: use an App Password (Google Account → Security → 2-Step → App passwords).
# ------------------------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraccount@gmail.com
SMTP_PASSWORD=your_16_char_app_password
SMTP_FROM_EMAIL=youraccount@gmail.com
SMTP_USE_TLS=true
# Port 465 (implicit SSL): set SMTP_USE_SSL=true and SMTP_USE_TLS=false

# NOTE: Copy this file, rename it to `.env` locally, and fill in your actual private values.
